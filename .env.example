# MoveMyTest environment template.
# Copy to .env and fill in real values. NEVER commit .env.

# ── Database (dev = u385361430_moveuser on local MySQL) ──
DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/movemytest?schema=public

# ── Session secrets ──
# Generate strong random secrets with:
#   node -e "console.log(crypto.randomBytes(48).toString('base64url'))"
# All session/MFA modules enforce a min length (48 for admin, 32 for others).
# If the secret is set but too short, sign-in fails with a clear error.
NEXTAUTH_URL=http://localhost:6003
AUTH_SECRET=                    # 48+ chars; used by admin session + as fallback for all others
TEST_SWAP_SECRET_KEY=           # 32+ chars; dedicated key for test-swap session/MFA modules

# ── DTC sync (read-only access to DTC database) ──
DTC_DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/u385361430_N

# ── DTC internal API (new path — uses API key) ──
DTC_API_URL=https://www.thedtc.co.uk/api/internal
INTERNAL_API_KEY=

# ── Old webhook config (deprecated, kept for backward compatibility) ──
DTC_WEBHOOK_URL=https://www.thedtc.co.uk/api/webhooks/mmt
DTC_WEBHOOK_SECRET=

# ── Google Analytics ──
NEXT_PUBLIC_GA_ID=

# ── Twilio SMS (set TWILIO_SMS_ENABLED=true to actually send) ──
TWILIO_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_ALPHANUMERIC_SENDER_ID=MoveMyTest
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

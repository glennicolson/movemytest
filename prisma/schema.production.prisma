  @@index([path])
  @@index([seoScore])
  @@index([lastScannedAt])
  @@index([pageViews30d])
}

model SeoSiteHealth {
  id                String   @id @default(cuid())
  robotsTxtPresent  Boolean  @default(false)
  robotsTxtContent  String?  @db.Text
  robotsTxtIssues   Json?
  sitemapXmlPresent Boolean  @default(false)
  sitemapXmlUrls    Int      @default(0)
  sitemapXmlIssues  Json?
  scanId            String?  @unique
  lastScannedAt     DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SeoScanAuditLog {
  id        String   @id @default(cuid())
  action    String // "TRIGGER_SCAN", "EXPORT_CSV", "EXPORT_PDF", "VIEW_DASHBOARD"
  userId    String
  userEmail String
  userRole  String
  metadata  Json? // { pagesScanned, pagesWithIssues, scanId }
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

model SeoScanLog {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  pagesScanned    Int       @default(0)
  pagesWithIssues Int       @default(0)
  status          String
  errorLog        String?   @db.Text
  triggeredBy     String
  createdAt       DateTime  @default(now())

  @@index([status])
  @@index([startedAt])
}

model GaApiCache {
  id         String   @id @default(cuid())
  metricType String
  dateRange  String
  data       Json
  fetchedAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([metricType, dateRange, expiresAt])
  @@index([expiresAt])
}


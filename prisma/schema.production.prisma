enum LearnerGoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model LearnerGoal {
  id            String            @id @default(cuid())
  learnerId     String
  instructorId  String
  title         String
  description   String?           @db.Text
  targetSkill   String?
  targetLevel   String?
  dueDate       DateTime?
  status          LearnerGoalStatus @default(ACTIVE)
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  learner       LearnerProfile    @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  instructor    InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([learnerId, status])
  @@index([instructorId])
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                   @id @default(cuid())
  email                      String                   @unique
  passwordHash               String?
  firstName                  String
  lastName                   String
  phone                      String?
  userType                   UserType
  role                       AppRole
  status                     AccountStatus            @default(INVITED)
  branchId                   String?
  lastLoginAt                DateTime?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  auditLogs                  AuditLog[]
  authTokens                 AuthToken[]
  backupCodes                BackupCode[]
  authoredBlogPosts          BlogPost[]               @relation("blogPostAuthor")
  sentCrmEmails              CrmEmailMessage[]        @relation("crmEmailSentBy")
  ownedCrmThreads            CrmEmailThreadWorkflow[] @relation("crmEmailThreadOwner")
  documents                  Document[]               @relation("documentUploadedBy")
  instructorProfile          InstructorProfile?
  learnerProfile             LearnerProfile?
  mfaFactors                 MfaFactor[]
  staffProfile               StaffProfile?
  testSwapListings           TestSwapListing[]
  testSwapLearnerAccount     TestSwapLearnerAccount?  @relation("crmUserTestSwapLearnerAccount")
  sentTestSwapLearnerInvites TestSwapLearnerInvite[]  @relation("testSwapLearnerInvitesSentByUser")
  testSwapMatchEvents        TestSwapMatchEvent[]
  testSwapReports            TestSwapReport[]
  testSwapAdminNotes         TestSwapAdminNote[]
  testSwapReportResponses    TestSwapReportResponse[]
  branch                     Branch?                  @relation(fields: [branchId], references: [id])
  instructorPayoutBatches    InstructorPayoutBatch[]
  leadNotes                  LeadNote[]
  createdDiaryEntries        DiaryEntry[]          @relation("diaryCreatedBy")
  assignedDiaryEntries       DiaryEntry[]          @relation("diaryAssignedTo")

  @@index([branchId], map: "User_branchId_fkey")
}

model AuthToken {
  id         String           @id @default(cuid())
  userId     String
  purpose    AuthTokenPurpose
  tokenHash  String           @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
}

model MfaFactor {
  id                   String          @id @default(cuid())
  userId               String
  method               MfaMethod
  status               MfaFactorStatus @default(PENDING)
  label                String?
  isPrimary            Boolean         @default(false)
  totpSecretEncrypted  String?         @db.Text
  webauthnCredentialId String?         @unique
  webauthnPublicKey    String?         @db.LongText
  webauthnCounter      Int?
  webauthnTransports   String?
  createdAt            DateTime        @default(now())
  activatedAt          DateTime?
  revokedAt            DateTime?
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, method, status])
}

model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model Branch {
  id           String              @id @default(cuid())
  name         String
  code         String              @unique
  status       BranchStatus        @default(ACTIVE)
  phone        String?
  email        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  postcode     String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  instructors  InstructorProfile[]
  invoices     Invoice[]
  leads        Lead[]
  learners     LearnerProfile[]
  lessons      Lesson[]
  users        User[]
}

model StaffProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  title     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InstructorProfile {
  id                        String                     @id @default(cuid())
  userId                    String                     @unique
  branchId                  String?
  area                      String?
  adiNumber                 String?
  vehicleMake               String?
  vehicleModel              String?
  vehicleRegistration       String?
  bio                       String?                    @db.Text
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  funFact                   String?                    @db.VarChar(280)
  photoUrl                  String?
  showOnWebsite             Boolean                    @default(false)
  specialties               String?
  teachesAutomatic          Boolean                    @default(false)
  teachesManual             Boolean                    @default(true)
  websiteBio                String?                    @db.Text
  yearsExperience           Int?
  addressCity               String?
  addressStreet             String?
  bankAccountName           String?
  bankAccountNumber         String?
  bankSortCode              String?
  dateJoinedDtc             DateTime?
  dateOfBirth               DateTime?
  lastCheckTestDate         DateTime?
  lastCheckTestGrade        String?
  licenceNumber             String?
  postcode                  String?
  branch                    Branch?                    @relation(fields: [branchId], references: [id])
  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceAreas              InstructorServiceArea[]
  unavailabilities          InstructorUnavailability[]
  availability              InstructorAvailability[]
  availabilityExceptions      InstructorAvailabilityException[]
  assignedLearners          LearnerProfile[]
  lessons                   Lesson[]
  payoutBatches             InstructorPayoutBatch[]
  testSwapInstructorAccount TestSwapInstructorAccount?
  testSwapLearnerInvites    TestSwapLearnerInvite[]
  learnerGoals              LearnerGoal[]
  lessonPrep                LessonPrep[]

  @@index([branchId], map: "InstructorProfile_branchId_fkey")
}

model LearnerProfile {
  id                        String                 @id @default(cuid())
  userId                    String                 @unique
  branchId                  String?
  assignedInstructorId      String?
  licenceNumber             String?
  provisionalExpiry         DateTime?
  targetTestDate            DateTime?
  onboardingStatus          String?
  learnerStatus             LearnerStatus           @default(ACTIVE)
  balancePence              Int                    @default(0)
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  addressCity               String?
  addressStreet             String?
  dateOfBirth               DateTime?
  homePhone                 String?
  licenceHeld               String?
  postcode                  String?
  title                     String?
  paymentMode               LearnerPaymentMode     @default(PAY_AS_YOU_GO)
  prepayBlockHours          Int?
  previousDrivingExperience String?
  eyesightTestDate          DateTime?
  adminNotes                String?                @db.Text
  collectionsCase           CollectionsCase?
  crmEmails                 CrmEmailMessage[]
  documents                 Document[]             @relation("documentsForLearner")
  invoices                  Invoice[]
  instructorPayoutItems     InstructorPayoutItem[]
  leads                     Lead[]
  assignedInstructor        InstructorProfile?     @relation(fields: [assignedInstructorId], references: [id])
  branch                    Branch?                @relation(fields: [branchId], references: [id])
  user                      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessons                   Lesson[]
  practicalTests            PracticalTest[]
  prepayBlocks              PrepayBlock[]
  progressRecordEntries     ProgressRecordEntry[]
  skillProgress             SkillProgress[]
  theoryTests               TheoryTest[]
  learnerGoals              LearnerGoal[]
  selfAssessments           LearnerSelfAssessment[]
  lessonPrep                LessonPrep[]

  @@index([assignedInstructorId], map: "LearnerProfile_assignedInstructorId_fkey")
  @@index([branchId], map: "LearnerProfile_branchId_fkey")
}

model Lead {
  id                  String            @id @default(cuid())
  firstName           String
  lastName            String
  email               String?
  phone               String?
  status              LeadStatus        @default(NEW)
  source              String?
  notes               String?           @db.Text
  preferredBranchId   String?
  convertedLearnerId  String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  title               String?
  dateOfBirth         String?
  homePhone           String?
  addressStreet       String?
  addressCity         String?
  postcode            String?
  licenceHeld         String?
  theoryTestPassed    String?
  practicalTestBooked String?
  practicalTestDetail String?
  previousExperience  String?
  daysAvailable       String?
  specialRequirements String?
  serviceRequired     String?
  hearAboutUs         String?
  crmEmails           CrmEmailMessage[]
  notesHistory         LeadNote[]
  convertedLearner    LearnerProfile?   @relation(fields: [convertedLearnerId], references: [id])
  preferredBranch     Branch?           @relation(fields: [preferredBranchId], references: [id])

  @@index([convertedLearnerId], map: "Lead_convertedLearnerId_fkey")
  @@index([preferredBranchId], map: "Lead_preferredBranchId_fkey")
}

model Lesson {
  id                String                  @id @default(cuid())
  branchId          String?
  learnerId         String
  instructorId      String
  status            LessonStatus            @default(DRAFT)
  transmission      TransmissionType        @default(MANUAL)
  startsAt          DateTime
  endsAt            DateTime
  pickupLocation    String?
  dropoffLocation   String?
  vehicleRequired   Boolean                 @default(true)
  learnerNotes      String?
  internalNotes     String?                 @db.Text
  attendanceStatus  LessonAttendanceStatus?
  taughtMinutes     Int?
  completedAt       DateTime?
  completionSummary String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  branch            Branch?                 @relation(fields: [branchId], references: [id])
  instructor        InstructorProfile       @relation(fields: [instructorId], references: [id])
  learner           LearnerProfile          @relation(fields: [learnerId], references: [id])
  lessonNotes       LessonNote[]
  preTestFor        PracticalTest?

  @@index([branchId], map: "Lesson_branchId_fkey")
  @@index([instructorId], map: "Lesson_instructorId_fkey")
  @@index([learnerId], map: "Lesson_learnerId_fkey")
}

model InstructorUnavailability {
  id           String            @id @default(cuid())
  instructorId String
  startsAt     DateTime
  endsAt       DateTime
  reason       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId])
  @@index([startsAt, endsAt])
}

// ── Instructor Availability (Working Hours) ──
model InstructorAvailability {
  id            String   @id @default(cuid())
  instructorId  String
  dayOfWeek     Int      // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime     String   // "HH:MM" format, e.g. "08:00"
  endTime       String   // "HH:MM" format, e.g. "18:00"
  isWorkingDay  Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  instructor    InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId])
  @@unique([instructorId, dayOfWeek])
}

// ── Instructor Availability Exception (overrides for specific dates) ──
model InstructorAvailabilityException {
  id            String   @id @default(cuid())
  instructorId  String
  exceptionDate DateTime @db.Date
  startTime     String?  // null = off all day
  endTime       String?  // null = off all day
  isWorkingDay  Boolean  @default(true)
  reason        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  instructor    InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId])
  @@index([exceptionDate])
  @@unique([instructorId, exceptionDate])
}

model LessonNote {
  id               String   @id @default(cuid())
  lessonId         String
  summary          String
  strengths        String?
  focusAreas       String?
  shareWithLearner Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lesson           Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId], map: "LessonNote_lessonId_fkey")
}

model ProgressRecordEntry {
  id            String                      @id @default(cuid())
  learnerId     String
  lessonId      String?
  date          DateTime
  hours         Float
  prepayBlockId String?
  paymentStatus ProgressRecordPaymentStatus @default(NOT_APPLICABLE)
  recap         String?
  introduce     String?
  comments      String?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  paymentMethod ProgressRecordPaymentMethod @default(NOT_PAID)
  amountPence   Int?
  payments      Payment[]
  learner       LearnerProfile              @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  prepayBlock   PrepayBlock?                @relation(fields: [prepayBlockId], references: [id])

  @@index([learnerId, date])
  @@index([paymentMethod, paymentStatus])
  @@index([prepayBlockId], map: "ProgressRecordEntry_prepayBlockId_fkey")
}

model PrepayBlock {
  id              String                @id @default(cuid())
  learnerId       String
  totalHours      Float
  hoursUsed       Float                 @default(0)
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  learner         LearnerProfile        @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  progressEntries ProgressRecordEntry[]

  @@index([learnerId, isActive])
}

model SkillProgress {
  id              String                  @id @default(cuid())
  learnerId       String
  skillCode       String
  skillLabel      String
  level           SkillLevel              @default(NOT_STARTED)
  confidence      LearnerConfidenceLevel?
  note            String?                 @db.Text
  focusNextLesson Boolean                 @default(false)
  lastAssessedAt  DateTime?
  updatedAt       DateTime                @updatedAt
  learner         LearnerProfile          @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@unique([learnerId, skillCode])
  @@index([learnerId, focusNextLesson])
}

model TheoryTest {
  id                String           @id @default(cuid())
  learnerId         String
  status            TheoryTestStatus @default(NOT_BOOKED)
  testDate          DateTime?
  testCentre        String?
  bookingReference  String?
  certificateNumber String?
  score             Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  learner           LearnerProfile   @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@index([learnerId], map: "TheoryTest_learnerId_fkey")
}

model PracticalTest {
  id                     String              @id @default(cuid())
  learnerId              String
  status                 PracticalTestStatus @default(NOT_BOOKED)
  testDate               DateTime?
  testCentre             String?
  bookingReference       String?
  testType               String?
  minorFaults            Int?
  majorFaults            Int?
  examinerName           String?
  resultSummary          String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  instructorTakingToTest Boolean             @default(false)
  preTestLessonId        String?             @unique
  learner                LearnerProfile      @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  preTestLesson          Lesson?             @relation(fields: [preTestLessonId], references: [id])

  @@index([learnerId], map: "PracticalTest_learnerId_fkey")
}

model TestCentre {
  id                  String                 @id @default(cuid())
  slug                String                 @unique
  officialName        String
  displayName         String
  region              String
  regionSlug          String
  country             TestCentreCountry
  sourceAgency        TestCentreSourceAgency
  addressLines        Json?
  postcode            String?
  latitude            Decimal?               @db.Decimal(9, 6)
  longitude           Decimal?               @db.Decimal(9, 6)
  centreType          String                 @default("practical driving test")
  active              Boolean                @default(true)
  sourceUrl           String                 @db.Text
  sourceLastCheckedAt DateTime
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  neighboursFrom      TestCentreNeighbour[]  @relation("CentreNeighboursFrom")
  neighboursTo        TestCentreNeighbour[]  @relation("CentreNeighboursTo")
  currentListings     TestSwapListing[]      @relation("CurrentTestCentre")
  originalListings    TestSwapListing[]      @relation("OriginalTestCentre")

  @@index([regionSlug])
  @@index([country, sourceAgency])
  @@index([active])
}

model TestCentreNeighbour {
  id            String     @id @default(cuid())
  centreId      String
  neighbourId   String
  distanceMiles Decimal?   @db.Decimal(6, 2)
  rank          Int
  sourceUrl     String     @db.Text
  createdAt     DateTime   @default(now())
  centre        TestCentre @relation("CentreNeighboursFrom", fields: [centreId], references: [id], onDelete: Cascade)
  neighbour     TestCentre @relation("CentreNeighboursTo", fields: [neighbourId], references: [id], onDelete: Cascade)

  @@unique([centreId, neighbourId])
  @@index([centreId, rank])
  @@index([neighbourId])
}

model TestSwapLearnerAccount {
  id                            String                           @id @default(cuid())
  crmUserId                     String?                          @unique
  email                         String                           @unique
  passwordHash                  String
  mobileNumber                  String?
  status                        TestSwapAccountStatus            @default(ACTIVE)
  termsAcceptedAt               DateTime
  privacyAcceptedAt             DateTime
  officialProcessAcknowledgedAt DateTime
  mobileContactConsentAt        DateTime?
  accountSetupCompletedAt       DateTime?
  marketingConsentAt            DateTime?
  emailVerifiedAt               DateTime?
  lastLoginAt                   DateTime?
  resetToken                    String?
  resetTokenExpiresAt           DateTime?
  createdAt                     DateTime                         @default(now())
  updatedAt                     DateTime                         @updatedAt
  consents                      TestSwapLearnerConsent[]
  listings                      TestSwapListing[]
  matchEvents                   TestSwapMatchEvent[]
  bookingReferenceSecrets       TestSwapBookingReferenceSecret[]
  reports                       TestSwapReport[]
  mfaFactors                    TestSwapLearnerMfaFactor[]
  backupCodes                   TestSwapLearnerBackupCode[]
  crmUser                       User?                            @relation("crmUserTestSwapLearnerAccount", fields: [crmUserId], references: [id], onDelete: SetNull, map: "ts_learner_crm_user_fk")
  invites                       TestSwapLearnerInvite[]
  notifications                 TestSwapLearnerNotification[]

  @@index([status, createdAt])
  @@index([crmUserId], map: "ts_learner_crm_user_idx")
}

model TestSwapLearnerMfaFactor {
  id                  String                 @id @default(cuid())
  accountId           String
  method              MfaMethod
  status              MfaFactorStatus        @default(PENDING)
  label               String?
  isPrimary           Boolean                @default(false)
  totpSecretEncrypted String?                @db.Text
  createdAt           DateTime               @default(now())
  activatedAt         DateTime?
  revokedAt           DateTime?
  account             TestSwapLearnerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, method, status], map: "ts_lmfa_account_method_status_idx")
}

model TestSwapLearnerBackupCode {
  id        String                 @id @default(cuid())
  accountId String
  codeHash  String                 @unique
  usedAt    DateTime?
  createdAt DateTime               @default(now())
  account   TestSwapLearnerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, usedAt], map: "ts_lbackup_account_used_idx")
}

model TestSwapLearnerInvite {
  id                           String                     @id @default(cuid())
  invitedByUserId              String?
  invitedByInstructorProfileId String?
  invitedByInstructorAccountId String?
  claimedByTestSwapAccountId   String?
  learnerName                  String?
  email                        String
  mobileNumber                 String?
  instructorAdiNumber          String?
  status                       String                     @default("PENDING")
  tokenHash                    String?
  inviteSentAt                 DateTime?
  inviteError                  String?                    @db.Text
  claimedAt                    DateTime?
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  invitedByUser                User?                      @relation("testSwapLearnerInvitesSentByUser", fields: [invitedByUserId], references: [id], onDelete: SetNull, map: "ts_linvite_user_fk")
  invitedByInstructorProfile   InstructorProfile?         @relation(fields: [invitedByInstructorProfileId], references: [id], onDelete: SetNull, map: "ts_linvite_crm_inst_fk")
  invitedByInstructorAccount   TestSwapInstructorAccount? @relation(fields: [invitedByInstructorAccountId], references: [id], onDelete: SetNull, map: "ts_linvite_ts_inst_fk")
  claimedByTestSwapAccount     TestSwapLearnerAccount?    @relation(fields: [claimedByTestSwapAccountId], references: [id], onDelete: SetNull, map: "ts_linvite_account_fk")

  @@index([email, status], map: "ts_linvite_email_status_idx")
  @@index([invitedByUserId, createdAt], map: "ts_linvite_user_created_idx")
  @@index([invitedByInstructorProfileId, createdAt], map: "ts_linvite_crm_inst_created_idx")
  @@index([invitedByInstructorAccountId, createdAt], map: "ts_linvite_ts_inst_created_idx")
  @@index([claimedByTestSwapAccountId], map: "ts_linvite_account_idx")
}

model TestSwapLearnerConsent {
  id             String                 @id @default(cuid())
  accountId      String
  consentType    String
  consentVersion String
  acceptedAt     DateTime               @default(now())
  ipAddress      String?
  userAgent      String?                @db.Text
  account        TestSwapLearnerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, consentType])
}

model TestSwapListing {
  id                        String                     @id @default(cuid())
  userId                    String?
  testSwapAccountId         String?
  currentCentreId           String
  originalCentreId          String?
  currentDateTime           DateTime
  bookingReferenceEncrypted String?                    @db.Text
  bookingReferenceIv        String?
  bookingReferenceAuthTag   String?
  testType                  TestSwapTestType
  hasRemainingChange        Boolean
  desiredDateFrom           DateTime
  desiredDateTo             DateTime
  desiredTimePreference     TestSwapTimePreference     @default(ANY)
  desiredCentreIds          Json
  desiredDirection          TestSwapDesiredDirection
  status                    TestSwapListingStatus      @default(ACTIVE)
  jurisdiction              TestSwapJurisdiction
  expiresAt                 DateTime
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  user                      User?                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  testSwapAccount           TestSwapLearnerAccount?    @relation(fields: [testSwapAccountId], references: [id], onDelete: Cascade)
  currentCentre             TestCentre                 @relation("CurrentTestCentre", fields: [currentCentreId], references: [id])
  originalCentre            TestCentre?                @relation("OriginalTestCentre", fields: [originalCentreId], references: [id])
  listingAMatches           TestSwapMatch[]            @relation("ListingAMatches")
  listingBMatches           TestSwapMatch[]            @relation("ListingBMatches")
  instructorDetails         TestSwapListingInstructor?
  reports                   TestSwapReport[]

  @@index([userId, status])
  @@index([testSwapAccountId, status])
  @@index([currentCentreId, status])
  @@index([jurisdiction, status])
  @@index([currentDateTime])
}

model TestSwapInstructorAccount {
  id                         String                                   @id @default(cuid())
  crmInstructorProfileId     String?                                  @unique
  adiNumber                  String                                   @unique
  firstName                  String
  lastName                   String
  email                      String                                   @unique
  mobileNumber               String?
  passwordHash               String
  status                     String                                   @default("ACTIVE")
  emailVerifiedAt            DateTime?
  mobileVerifiedAt           DateTime?
  lastLoginAt                DateTime?
  resetToken                 String?
  resetTokenExpiresAt        DateTime?
  verificationToken          String?
  verificationTokenExpiresAt DateTime?
  createdAt                  DateTime                                 @default(now())
  updatedAt                  DateTime                                 @updatedAt
  listingLinks               TestSwapListingInstructor[]
  invites                    TestSwapInstructorInvite[]
  learnerInvites             TestSwapLearnerInvite[]
  availabilityDecisions      TestSwapInstructorAvailabilityDecision[]
  auditLogs                  TestSwapInstructorAuditLog[]
  mfaFactors                 TestSwapInstructorMfaFactor[]
  backupCodes                TestSwapInstructorBackupCode[]
  crmInstructorProfile       InstructorProfile?                       @relation(fields: [crmInstructorProfileId], references: [id], onDelete: SetNull, map: "ts_inst_crm_profile_fk")

  @@index([adiNumber, status])
  @@index([email, status])
  @@index([crmInstructorProfileId], map: "ts_inst_crm_profile_idx")
}

model TestSwapInstructorInvite {
  id                  String                     @id @default(cuid())
  listingInstructorId String
  instructorAccountId String?
  email               String
  adiNumber           String
  tokenHash           String?
  status              String                     @default("PENDING")
  inviteSentAt        DateTime?
  inviteError         String?                    @db.Text
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  listingInstructor   TestSwapListingInstructor  @relation(fields: [listingInstructorId], references: [id], onDelete: Cascade)
  instructorAccount   TestSwapInstructorAccount? @relation(fields: [instructorAccountId], references: [id], onDelete: SetNull)

  @@index([email, status])
  @@index([adiNumber, status])
  @@index([listingInstructorId])
}

model TestSwapListingInstructor {
  id                                  String                                   @id @default(cuid())
  listingId                           String                                   @unique
  instructorAccountId                 String?
  adiNumber                           String?
  firstName                           String?
  lastName                            String?
  email                               String?
  mobileNumber                        String?
  learnerConfirmedPermissionAt        DateTime?
  learnerConfirmedAvailabilityCheckAt DateTime?
  inviteSentAt                        DateTime?

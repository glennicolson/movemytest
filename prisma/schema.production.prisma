// ── Admin Diary ──

enum DiaryPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DiaryStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model DiaryEntry {
  id              String        @id @default(cuid())
  title           String
  description     String?       @db.Text
  dueDate         DateTime
  durationMinutes Int?
  priority        DiaryPriority @default(MEDIUM)
  status          DiaryStatus   @default(PENDING)
  recurrence      String?       // NONE, DAILY, WEEKLY, MONTHLY
  recurrenceUntil DateTime?
  seriesId        String?       // Links recurring entries together
  entityType      String?
  entityId        String?
  assignedUserId  String?
  createdByUserId String
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  createdBy User  @relation("diaryCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo User? @relation("diaryAssignedTo", fields: [assignedUserId], references: [id])

  @@index([dueDate])
  @@index([status])
  @@index([entityType, entityId])
  @@index([assignedUserId])
  @@index([createdByUserId])
  @@index([seriesId])
}

model TestSwapInstructorMfaFactor {
  id                  String                    @id @default(cuid())
  accountId           String
  method              MfaMethod
  status              MfaFactorStatus           @default(PENDING)
  label               String?
  isPrimary           Boolean                   @default(false)
  totpSecretEncrypted String?                   @db.Text
  createdAt           DateTime                  @default(now())
  activatedAt         DateTime?
  revokedAt           DateTime?
  account             TestSwapInstructorAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, method, status], map: "ts_imfa_account_method_status_idx")
}

model TestSwapInstructorBackupCode {
  id        String                    @id @default(cuid())
  accountId String
  codeHash  String                    @unique
  usedAt    DateTime?
  createdAt DateTime                  @default(now())
